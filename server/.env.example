# FAL AI API Key (required for image/video generation)
FAL_KEY=your_fal_api_key_here

# kie.ai API Key (second aggregator — GPT-4o Image, Flux Kontext Max,
# Midjourney, Veo 3 / Veo 3 Fast). kie models 503 until this is set; FAL
# models are unaffected. Real value lives ONLY in server/.env locally and as
# an App-Level Encrypted env var in the DO dashboard (NOT .do/app.yaml).
KIE_KEY=your_kie_api_key_here

# Server port (DO App Platform overrides this with $PORT=8080 at runtime)
PORT=3001

# ─── Postgres (auth + future entity storage) ────────────────────────
# On DigitalOcean App Platform with an attached database, leave the value
# blank and instead set the env var in the dashboard to ${voxel-db.DATABASE_URL}
# so DO injects it automatically.
# Locally, point this at a dev Postgres instance:
#   docker run --rm -p 5432:5432 -e POSTGRES_PASSWORD=dev postgres:16
#   DATABASE_URL=postgres://postgres:dev@localhost:5432/postgres
DATABASE_URL=

# ─── Auth ───────────────────────────────────────────────────────────
# JWT_SECRET signs login tokens. MUST be set in production. Generate one:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# In DO App Platform, store this as an Encrypted env var, never commit it.
JWT_SECRET=
JWT_EXPIRES_IN=7d
ADMIN_JWT_EXPIRES_IN=30m

# ─── Admin ──────────────────────────────────────────────────────────
# The single email that gets promoted to role='admin' on every server boot
# (idempotent — only flips role if the row exists and isn't already admin).
ADMIN_EMAIL=info@voxel-ai.ai

# ─── Credit costs ───────────────────────────────────────────────────
# Cost per generation in credits. Float allowed (NUMERIC(10,2) column).
# Change anytime — no migration needed, just restart the server.
CREDIT_COST_IMAGE=2
CREDIT_COST_VIDEO=10

# ─── Object storage (DigitalOcean Spaces) ──────────────────────────
# Durable storage for GENERATED images/videos. FAL's output links expire, so
# we copy each output into our own Spaces bucket and store OUR url in history.
# If these are blank, storage is DISABLED and history keeps the raw (expiring)
# FAL url — set them in production so old images never disappear again.
#   1. Create a Space + an access key in the DO dashboard (API → Spaces Keys).
#   2. SPACES_ENDPOINT is the REGION host, not the bucket host.
SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
SPACES_REGION=fra1
SPACES_BUCKET=voxel-media
SPACES_KEY=
SPACES_SECRET=
# Optional: public CDN base. If unset, urls are derived from endpoint+bucket.
SPACES_CDN_BASE=

# ─── CORS ───────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Defaults to voxel-ai.ai + local
# Vite dev (5173) + local Docker web (8080).
ALLOWED_ORIGINS=https://voxel-ai.ai,http://localhost:5173,http://localhost:8080
